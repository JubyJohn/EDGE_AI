#include <Adafruit_NeoPixel.h>
#include <Motion_detection_inferencing.h>

#define X_PIN 1
#define Y_PIN 2
#define LED_PIN 48

Adafruit_NeoPixel led(1, LED_PIN, NEO_GRB + NEO_KHZ800);

void setup() {
  Serial.begin(115200);
  led.begin();
  led.show();
}

void loop() {
  float buffer[2];

  buffer[0] = analogRead(X_PIN);
  buffer[1] = analogRead(Y_PIN);

  signal_t signal;
  numpy::signal_from_buffer(buffer, 2, &signal);

  ei_impulse_result_t result;
  run_classifier(&signal, &result, false);

  // FIND BEST LABEL (IMPORTANT FIX)
  float maxVal = 0;
  String label = "";

  for (size_t i = 0; i < EI_CLASSIFIER_LABEL_COUNT; i++) {
    if (result.classification[i].value > maxVal) {
      maxVal = result.classification[i].value;
      label = result.classification[i].label;
    }
  }

  Serial.println(label);

  // RGB LED CONTROL
  if (label == "up") {
    led.setPixelColor(0, led.Color(0, 0, 255));   // Blue
  }
  else if (label == "down") {
    led.setPixelColor(0, led.Color(255, 0, 0));   // Red
  }
  else if (label == "left") {
    led.setPixelColor(0, led.Color(0, 255, 0));   // Green
  }
  else if (label == "right") {
    led.setPixelColor(0, led.Color(255, 255, 0)); // Yellow
  }
  else {
    led.setPixelColor(0, led.Color(0, 0, 0));     // OFF (center)
  }

  led.show();
  delay(100);
}

