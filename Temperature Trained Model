Temperature monitoring Model

✅ Step 1: Upload code on Arduino IDE 

#include "DHT.h"

#define DHTPIN 4
#define DHTTYPE DHT11

DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Serial.begin(115200);
  dht.begin();
}

void loop() {
  float temp = dht.readTemperature();

  if (isnan(temp)) {
    Serial.println("Error");
  } else {
    Serial.println(temp);  // Send ONLY temperature
  }

  delay(2000);
}

* Connect ESP32-S3 with DHT11
 3V3 -> VCC
  4  -> Data
 GND -> GND

* Check on serial monitor , to make sure it shows only temperature


